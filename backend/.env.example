# Copy to .env and fill in. NEVER commit the real .env.
# Hard rule (roadmap §5/§9): every provider key lives ONLY on the backend.
# The frontend talks only to our /api/* endpoints; it never sees these.

# Anthropic API key — scenario generation + content scoring (Phase 2).
ANTHROPIC_API_KEY=

# Optional: override the content model (defaults to claude-sonnet-4-6).
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Transcription API key (Phase 3, voice). Default provider is AssemblyAI —
# create a key at assemblyai.com and SET A SPEND CAP first (roadmap §9).
# Without this, typed practice still works; the Speak option returns a 503.
TRANSCRIPTION_API_KEY=
# TRANSCRIPTION_PROVIDER=assemblyai

# Analytics (PostHog) — optional. The project key is a PUBLIC, write-only ingest
# key (safe to expose); the SPA fetches it via /api/config. Leave empty to
# disable analytics entirely. Create a project at posthog.com.
POSTHOG_KEY=
# POSTHOG_HOST=https://us.i.posthog.com
